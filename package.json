{
  "name": "web-ai-agent",
  "version": "1.0.0",
  "description": "云商 AI Agent应用",
  "license": "ISC",
  "author": "zhangyanhan01@corp.netease.com",
  "main": "index.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production pp yspack build",
    "build:prod": "npm run build && npm run upload",
    "build:report": "cross-env ANALYZE=1 npm run build",
    "deploy": "web-deploy --distPath=dist --projectName=web-ai-agent",
    "dev": "cross-env NODE_ENV=development pp yspack dev",
    "postinstall": "is-ci || git config core.hooksPath .git/hooks/ && simple-git-hooks",
    "lint": "npm run lint:script && npm run lint:style",
    "lint:script": "biome check --diagnostic-level=error --no-errors-on-unmatched --max-diagnostics=100 src/**/*",
    "lint:style": "stylelint 'src/**/*.less'",
    "lint-fix": "npm run lint-fix:script && npm run lint-fix:style",
    "lint-fix:script": "npm run lint:script -- --write",
    "lint-fix:style": "npm run lint:style -- --fix",
    "lock": "npx pkg update",
    "start": "npm run dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx checkit pre-commit && npx pkg pre-commit && npx lint-staged",
    "commit-msg": "npx checkit commit-msg",
    "pre-push": "npx checkit pre-push"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": "biome check --diagnostic-level=error --no-errors-on-unmatched --max-diagnostics=100 --write",
    "*.less": "stylelint --fix",
    "*.{md,yml}": "prettier --write"
  },
